server {
  listen 8082 ssl;
  http2 on;

  # UDP: QUIC (HTTP/3)
  listen 8082 quic reuseport;
  http3 on;

  server_name _;

  ssl_certificate     /home/n2sl/yeon/metric/ssl/dev.crt;
  ssl_certificate_key /home/n2sl/yeon/metric/ssl/dev.key;
  ssl_protocols TLSv1.3;
  ssl_prefer_server_ciphers off;
  # 브라우저가 h3로 전환하도록 광고
  add_header Alt-Svc 'h3=":443"; ma=86400' always;

  root /home/n2sl/yeon/metric/video_client/360EAVP;
  index Index.html;

  location / {
    try_files $uri $uri/ =404;
  }

  location ~* \.(mpd|m4s|mp4|webm)$ {
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, HEAD, OPTIONS" always;
    add_header Access-Control-Allow-Headers "*" always;

    if ($request_method = OPTIONS) { return 204; }
  }
}


