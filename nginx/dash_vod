server {
    listen 8089 ssl;

    server_name _;
    
    ssl_certificate     /home/n2sl/yeon/metric/ssl/dev.crt;
    ssl_certificate_key /home/n2sl/yeon/metric/ssl/dev.key;
    
    # DASH VOD: /vod/... -> /home/n2sl/yeon/metric/dash/output/...
    location /vod/ {
        alias /home/n2sl/yeon/metric/dash_vod/output/;
        autoindex off;

        # CORS (클라이언트가 다른 포트/도메인에서 접근할 때)
        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET, HEAD, OPTIONS" always;
        add_header Access-Control-Allow-Headers "*" always;

        if ($request_method = OPTIONS) { return 204; }

        # MIME types
        types {
            application/dash+xml mpd;
            video/iso.segment m4s;
            video/mp4 mp4;
        }

        # 캐시
        expires 1h;
        add_header Cache-Control "public" always;
    }
}
