server {
    listen 8092 ssl;
    http2 on;

    # UDP: QUIC (HTTP/3)
    listen 8092 quic reuseport;
    http3 on;

    server_name _;

    ssl_certificate     /home/n2sl/yeon/metric/ssl/dev.crt;
    ssl_certificate_key /home/n2sl/yeon/metric/ssl/dev.key;

    # 브라우저가 h3로 업그레이드하도록 광고
    add_header Alt-Svc 'h3=":8446"; ma=86400' always;
    
    root /home/n2sl/yeon/metric/video-client;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}
