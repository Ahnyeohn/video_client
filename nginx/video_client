server {
    listen 8091;
    server_name _;

    root /home/n2sl/yeon/metric/video-client;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}
server {
    listen 8092 ssl;

    server_name _;

    ssl_certificate     /home/n2sl/yeon/metric/ssl/dev.crt;
    ssl_certificate_key /home/n2sl/yeon/metric/ssl/dev.key;

    root /home/n2sl/yeon/metric/video-client;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}
